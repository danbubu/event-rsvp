# Copy to `.env.local` for local dev. On Vercel, add the same keys under
# Project → Settings → Environment Variables (use Production / Preview as needed).

# Supabase (NEXT_PUBLIC_* are embedded in the client bundle — protect data with RLS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose in client code or NEXT_PUBLIC_*
SUPABASE_SERVICE_ROLE_KEY=

# Auth API (/api/auth/*) — use a long random string in production (openssl rand -hex 32)
JWT_SECRET=

# Optional: MySQL (dashboard / events / auth)
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=

# Optional: RSVP confirmation email (Resend preferred)
RESEND_API_KEY=
RESEND_FROM=

# Optional: SMTP fallback if you do not use Resend
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Optional: append RSVPs to Google Sheets
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_ID=
