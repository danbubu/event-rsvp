# =============================================================================
# Copy to .env.local (local) and mirror in Vercel → Settings → Environment
# Variables (Production / Preview). Never commit .env.local.
# =============================================================================

# --- Supabase (required for POST /api/rsvp + DB storage) ----------------------
# Dashboard: https://supabase.com/dashboard → your project → Project Settings → API
#   NEXT_PUBLIC_SUPABASE_URL        → "Project URL"
#   NEXT_PUBLIC_SUPABASE_ANON_KEY   → "anon" "public" key (safe in browser; use RLS)
#   SUPABASE_SERVICE_ROLE_KEY       → "service_role" key (SECRET — server only)
# Also: SQL Editor → create table `rsvps` with columns your route inserts.
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- JWT (required if you use /api/auth/login, register, me — events app) -----
# Generate: openssl rand -hex 32   (or any long random string)
JWT_SECRET=

# --- MySQL (optional — used by auth/events/analytics routes that call database.ts)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=event_rsvp_db

# --- Email — Resend (recommended) OR SMTP fallback --------------------------
# Resend: https://resend.com → API Keys → create key. Add domain for production "from".
RESEND_API_KEY=
# Optional; default is "<hostName> Party <onboarding@resend.dev>" (Resend test sender)
RESEND_FROM=

# SMTP fallback (optional — Nodemailer if no RESEND_API_KEY)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Google Sheets backup (optional — appended only if ALL three vars below are non-empty)
# Google Cloud Console → project → APIs → enable "Google Sheets API"
# IAM → Service Accounts → create → Keys → JSON; use client_email + private_key
# Share the spreadsheet with the service account email (Editor).
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste full key; use \n for newlines, or real newlines inside quotes in .env.local
GOOGLE_PRIVATE_KEY=
# Sheet ID only, or paste the full spreadsheet URL — the app extracts the ID
GOOGLE_SHEET_ID=
